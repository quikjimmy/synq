{
  "expo": {
    "name": "Synq Operator",
    "slug": "synq-operator-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0057FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.synqai.operator",
      "infoPlist": {
        "NFCReaderUsageDescription": "Used to simulate RFID reader taps for the manifest demo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0057FF"
      },
      "package": "com.synqai.operator",
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "react-native-nfc-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "546cd2e6-8c45-4f47-9fa6-d8f6543ce0c3"
      }
    },
    "owner": "jamestootill"
  }
}
